{
  "version": 2,
  "builds": [
    {
      "src": "dashboard/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/logo.jpg", "dest": "/dashboard/logo.jpg" },
    { "src": "/favicon.ico", "dest": "/dashboard/logo.jpg" },
    { "src": "/(.*)", "dest": "/dashboard/index.html" }
  ]
}
