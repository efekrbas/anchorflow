# ============================================================
# AnchorFlow Stellar Service — Environment Configuration
# ============================================================

# The secret key for the sending/client account.
# NEVER commit the real value to version control.
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# The public key derived from the secret above (G...).
STELLAR_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stellar network to use: "testnet" | "public"
STELLAR_NETWORK=testnet

# The home domain of the Anchor you are integrating with.
# This is used to discover the anchor's TOML and SEP endpoints.
# Example: testanchor.stellar.org
ANCHOR_DOMAIN=testanchor.stellar.org

# Port for the Express server
PORT=3001
